[Unit]
Description=aipanel STT service (faster-whisper streaming)
Documentation=https://github.com/aipanel/aipanel
After=postgresql.service redis-server.service aipanel-llm.service network-online.target
Wants=network-online.target

[Service]
Type=simple
User=aipanel
Group=aipanel

EnvironmentFile=/etc/aipanel/secrets.env
Environment=CUDA_VISIBLE_DEVICES=0

ExecStart=/opt/aipanel/stt-server/.venv/bin/python -m aipanel_stt.main

TimeoutStartSec=300
Restart=on-failure
RestartSec=10

LimitNOFILE=65536
LimitMEMLOCK=infinity

StandardOutput=append:/var/log/aipanel/stt.log
StandardError=append:/var/log/aipanel/stt.log

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/log/aipanel /var/lib/aipanel

[Install]
WantedBy=multi-user.target
