# Local-dev secrets — match the values baked into dev/docker-compose.yml.
# Loaded by the panel backend via AIPANEL_SECRETS=dev/secrets.dev.env.
# DO NOT use these values anywhere except the local docker-compose.

DB_PASSWORD=devpassword
REDIS_PASSWORD=
MINIO_ACCESS_KEY=aipaneldev
MINIO_SECRET_KEY=devpassword

# JWT signing key — random hex; OK for local dev.
JWT_SECRET=2b2e1d4f5a6c7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f

# Session-mgr inter-service auth (panel → session-mgr).
SESSION_MGR_TOKEN=devtoken-not-secret

# Crypto.encrypt() key — Fernet key (urlsafe-base64 of 32 random bytes).
ENCRYPTION_KEY=bBFa2NVgqI7BHpABSFJg4DKNdxZ4ufXuebOZVkuVgJU=
